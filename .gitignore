# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── Environment variables / secrets ───────────────────────────────────────────
.env
*.env
secrets.py

# ── Weather app specific ───────────────────────────────────────────────────────
# Cached icons (downloaded automatically on first run)
icons/
# Saved favourite cities (user-specific, not part of the source code)
favorites.json

# ── Pytest cache ───────────────────────────────────────────────────────────────
.pytest_cache/
.cache/
*.pytest_cache

# ── IDEs and editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Build / distribution ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
